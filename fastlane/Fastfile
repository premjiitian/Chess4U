require "base64"
require "openssl"

# ── OpenSSL 3.x compat ────────────────────────────────────────────────────────
# Load the legacy provider early so PKey.read can decode keys that were
# generated with explicit EC curve parameters instead of a named-curve OID.
begin
  OpenSSL::Provider.load("legacy") if defined?(OpenSSL::Provider)
rescue => _e
  # Non-fatal: the provider may not be available or already loaded.
end

# spaceship calls OpenSSL::PKey::EC.new(pem_string) which ruby-openssl 3.x no
# longer accepts for PKCS#8-wrapped keys.  Intercept the failure and try a
# series of loading strategies until one works.
OpenSSL::PKey::EC.singleton_class.prepend(Module.new do
  def new(*args, &block)
    super
  rescue OpenSSL::PKey::ECError, OpenSSL::PKey::PKeyError, TypeError
    raise if args.empty? || !args.first.is_a?(String)
    raw = args.first

    # ── Diagnostics (no key material – header bytes + structural info only) ──
    $stderr.puts "[key-compat] EC.new intercepted. " \
      "size=#{raw.bytesize} is_pem=#{raw.include?('-----BEGIN')} " \
      "header=#{raw.byteslice(0, 5).inspect}"

    # Strategy 1 – raw as-is: standard PKCS#8 PEM/DER, or traditional EC PEM
    begin
      return OpenSSL::PKey.read(raw)
    rescue => e
      $stderr.puts "[key-compat] s1 (raw) failed: #{e.message}"
    end

    # Strategy 2 – raw is still base64 (secret was double-base64-encoded)
    begin
      return OpenSSL::PKey.read(Base64.decode64(raw))
    rescue => e
      $stderr.puts "[key-compat] s2 (double-decode) failed: #{e.message}"
    end

    # Strategy 3 – secret has literal \n instead of real newlines
    begin
      return OpenSSL::PKey.read(raw.gsub('\n', "\n"))
    rescue => e
      $stderr.puts "[key-compat] s3 (unescape-newlines) failed: #{e.message}"
    end

    raise OpenSSL::PKey::PKeyError,
      "[key-compat] Could not load API key in any format. " \
      "Ensure APP_STORE_CONNECT_API_KEY_BASE64 contains the base64-encoded " \
      "content of the .p8 file downloaded from the Apple Developer portal."
  end
end)

default_platform(:ios)

platform :ios do

  # ── Helpers ──────────────────────────────────────────────────────────────

  def api_key
    raw = ENV["APP_STORE_CONNECT_API_KEY_BASE64"].to_s
    # If the secret holds the raw .p8 PEM text instead of its base64 encoding,
    # tell spaceship not to base64-decode it a second time.
    is_b64 = !raw.strip.start_with?("-----BEGIN")
    $stderr.puts "[api-key] key_length=#{raw.length} is_base64=#{is_b64}"
    app_store_connect_api_key(
      key_id:                ENV["APP_STORE_CONNECT_API_KEY_ID"],
      issuer_id:             ENV["APP_STORE_CONNECT_ISSUER_ID"],
      key_content:           raw,
      is_key_content_base64: is_b64
    )
  end

  def git_auth
    Base64.strict_encode64("x-access-token:#{ENV['GH_PAT']}")
  end

  # ── Lanes ────────────────────────────────────────────────────────────────

  desc "Run unit tests"
  lane :test do
    run_tests(
      project:      "Chess4U.xcodeproj",
      scheme:       "Chess4U",
      device:       "iPhone 16 Pro",
      result_bundle: true
    )
  end

  desc "Initialize Match — run ONCE to generate & store certificates (no Mac needed)"
  lane :init_match do
    match(
      type:                    "appstore",
      readonly:                false,
      force:                   ENV.fetch("MATCH_FORCE_RECREATE", "false") == "true",
      git_basic_authorization: git_auth,
      api_key:                 api_key,
      skip_set_partition_list: true
    )
  end

  desc "Build and upload to TestFlight"
  lane :beta do
    key = api_key

    # Create a short-lived keychain so the signing key is unlocked and
    # accessible to xcodebuild without any UI permission popup on CI.
    keychain_name     = "ci-build.keychain"
    keychain_password = "ci-temp"
    create_keychain(
      name:              keychain_name,
      password:          keychain_password,
      default_keychain:  true,
      unlock:            true,
      timeout:           3600,
      add_to_search_list: true
    )

    # Fetch certificates & provisioning profiles from the private certs repo
    match(
      type:                    "appstore",
      readonly:                true,
      git_basic_authorization: git_auth,
      api_key:                 key,
      keychain_name:           keychain_name,
      keychain_password:       keychain_password
    )

    # Version from git tag (v1.2.3 → 1.2.3), build from run number
    version = (ENV["GITHUB_REF_NAME"] || "1.0.0").sub(/^v/, "")
    build   = ENV["GITHUB_RUN_NUMBER"] || "1"

    increment_version_number(version_number: version)
    increment_build_number(build_number:   build)

    # Switch to manual signing so xcodebuild uses the match-installed
    # App Store profile. Match exports the profile name as an env var
    # after downloading it — derive from that instead of hardcoding.
    profile_env_key = "MATCH_PROVISIONING_PROFILE_APPSTORE_COM_CHESS4U_CHESS4U"
    profile_name    = ENV.fetch(profile_env_key) do
      UI.user_error!("#{profile_env_key} is not set — did 'match' run successfully?")
    end

    update_code_signing_settings(
      use_automatic_signing: false,
      path:               "Chess4U.xcodeproj",
      team_id:            ENV["DEVELOPMENT_TEAM"],
      code_sign_identity: "Apple Distribution",
      profile_name:       profile_name
    )

    # Build & sign
    build_app(
      project:       "Chess4U.xcodeproj",
      scheme:        "Chess4U",
      configuration: "Release",
      export_method: "app-store"
    )

    # Upload to TestFlight
    upload_to_testflight(
      api_key:                            key,
      skip_waiting_for_build_processing:  true
    )
  end

  desc "Capture App Store screenshots on simulators"
  lane :screenshots do
    capture_screenshots(
      project:                    "Chess4U.xcodeproj",
      scheme:                     "Chess4UUITests",
      output_directory:           "fastlane/screenshots",
      clear_previous_screenshots: true,
      override_status_bar:        true,
      derived_data_path:          "DerivedData"
    )
  end

  desc "Submit latest TestFlight build to App Store review"
  lane :release do
    key = api_key

    upload_to_app_store(
      api_key:              key,
      skip_binary_upload:   true,          # reuse build already on TestFlight
      skip_screenshots:     false,
      screenshots_path:     "fastlane/screenshots",
      metadata_path:        "fastlane/metadata",
      force:                true,          # skip HTML preview prompt
      submit_for_review:    true,
      automatic_release:    false,         # manual release after Apple approval
      submission_information: {
        add_id_info_uses_idfa:                       false,
        export_compliance_uses_encryption:            false,
        export_compliance_is_exempt:                  true,
        content_rights_has_rights:                   true,
        content_rights_contains_third_party_content: false
      }
    )
  end

end
