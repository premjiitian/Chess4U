# Copy this file to scripts/.env and fill in your values.
# NEVER commit scripts/.env — it is already in .gitignore.
#
# Where to find each value:
#   MATCH_GIT_URL         – URL of your private GitHub repo used to store
#                           encrypted certificates (create an empty private repo
#                           and paste its HTTPS clone URL here)
#   MATCH_PASSWORD        – Any strong passphrase you choose; match uses it to
#                           encrypt the certs before pushing them
#   GH_PAT                – GitHub → Settings → Developer Settings →
#                           Personal Access Tokens → Tokens (classic) →
#                           Generate new token → scope: repo
#   DEVELOPMENT_TEAM      – Xcode → Signing & Capabilities → Team ID
#                           (also visible at developer.apple.com → Membership)
#   APP_STORE_CONNECT_*   – App Store Connect → Users and Access → Keys →
#                           Generate API Key → download the .p8 file

MATCH_GIT_URL=https://github.com/YOUR_USERNAME/chess4u-certs
MATCH_PASSWORD=your-strong-passphrase-here
GH_PAT=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
DEVELOPMENT_TEAM=XXXXXXXXXX
APP_STORE_CONNECT_API_KEY_ID=XXXXXXXXXX
APP_STORE_CONNECT_ISSUER_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
# Paste the raw content of the .p8 file OR its base64 encoding — both work:
APP_STORE_CONNECT_API_KEY_BASE64=LS0tLS1CRUdJTiBQUklWQVRFIEtFWS0tLS0t...
